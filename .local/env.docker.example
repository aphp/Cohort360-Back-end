# Copier vers `.env` à la racine du repo pour `docker compose -f docker-compose.dev.yml up`.
# Les hôtes DB / Redis sont surchargés par docker-compose.dev.yml (postgres, redis).
# Depuis le conteneur, les services sur ta machine : host.docker.internal (déjà ajouté dans compose).

DEBUG=True
DJANGO_SECRET_KEY=changeme-generate-a-long-random-string
INCLUDED_APPS=accesses,cohort_job_server,cohort,exporters,exports,content_management,accesses_fhir_perimeters

# Entrée HTTP = runserver du service backend (docker-compose.dev.yml:8000:8000)
BACKEND_HOST=localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

DB_NAME=cohort_db
DB_USER=cohort_dev
DB_PASSWORD=cohort_dev_pwd

# Même base que DB_NAME en dev docker (postgres ne crée qu’une base POSTGRES_DB)
PERIMETERS_SOURCE_DB_NAME=cohort_db
PERIMETERS_SOURCE_DB_USER=cohort_dev
PERIMETERS_SOURCE_DB_PASSWORD=cohort_dev_pwd
PERIMETERS_SOURCE_DB_SCHEMA=public
ROOT_PERIMETER_ID=0
PERIMETER_TYPES=AP-HP,GHU,Hôpital,Groupe hospitalier (GH),Pôle/DMU,Unité Fonctionnelle (UF)
REPORTING_PERIMETER_TYPES=AP-HP,GHU,Hôpital,Groupe hospitalier (GH),Pôle/DMU,Unité Fonctionnelle (UF)

# JWT / OIDC / cohort / email : reprendre .local/loca-env.template et adapter les URLs.
# Important : ne pas utiliser le même port que BACKEND_HOST pour FHIR (ex. backend 8000 → FHIR sur autre port).
# Exemple FhirApi sur l’hôte port 8088 :
FHIR_URL=http://host.docker.internal:8088/fhir
QUERY_EXECUTOR_URL=http://host.docker.internal:8091

JWT_ALGORITHMS=RS256,HS256
JWT_SIGNING_KEY=33eecb0be4a628a8645bb9b5059300c69bbe3032568ae424591f44b3b56c35c4
ENABLE_OIDC_AUTH=true
OIDC_AUTH_SERVER_1=http://host.docker.internal:8090/auth/realms/master
OIDC_REDIRECT_URI_1=https://localhost:8090/
OIDC_CLIENT_SECRET_1=test
OIDC_CLIENT_ID_1=test
OIDC_AUTH_SERVER_2=http://host.docker.internal:8090/auth/realms/AP-HP
OIDC_REDIRECT_URI_2=https://localhost:8090/
OIDC_CLIENT_SECRET_2=test
OIDC_CLIENT_ID_2=test
OIDC_AUTH_SERVER_3=http://host.docker.internal:8090/auth/realms/ID-Interne
OIDC_REDIRECT_URI_3=https://localhost:8090/
OIDC_CLIENT_SECRET_3=test
OIDC_CLIENT_ID_3=test
OIDC_AUDIENCE=cohort360,api-fhir,api-portal,api-portal-dev

ROLLOUT_TOKEN=local-dev-token
ROLLOUT_USERNAME=testuser

QUERY_EXECUTOR_TOKEN=
QUERY_EXECUTOR_USERNAME=SPARK_JOB_SERVER
USE_SOLR=True

EMAIL_HOST=host.docker.internal
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@cohort360.local
EMAIL_USE_TLS=False
IDENTITY_SERVER_URL=http://host.docker.internal:8090
DISABLE_DATA_TRANSLATION=false